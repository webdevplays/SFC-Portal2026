{
  "name": "react-example",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/prepare.cjs && tsx server.ts",
    "build": "node scripts/prepare.cjs && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=server.cjs && node scripts/postbuild.cjs",
    "start": "node server.cjs",
    "clean": "rm -rf dist server.cjs server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.22.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.0",
    "@tailwindcss/oxide-linux-arm64-gnu": "^4.0.0",
    "@tailwindcss/oxide-linux-x64-musl": "^4.0.0",
    "@tailwindcss/oxide-linux-arm64-musl": "^4.0.0"
  }
}
